# Used in the HTTP User-Agent. Replace before enabling the timer.
POLICY_AGENT_CONTACT_EMAIL=you@example.com

# Git settings for scheduled data commits.
GIT_REMOTE=origin
GIT_BRANCH=main
GIT_COMMIT_NAME=Policy Opportunity Agent
GIT_COMMIT_EMAIL=policy-agent@localhost
GIT_PULL_BEFORE_RUN=true
GIT_PULL_REQUIRED=false
LOG_LEVEL=INFO
